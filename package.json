{
  "name": "web-monitoring",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:server": "node --watch src/server.js",
    "dev:client": "vite --config frontend/vite.config.js",
    "dev": "concurrently -n server,client -c cyan,green \"npm:dev:server\" \"npm:dev:client\"",
    "build:client": "vite build --config frontend/vite.config.js",
    "start": "node src/server.js"
  },
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "@fastify/static": "^6.12.0",
    "better-sqlite3": "^9.6.0",
    "chart.js": "^4.4.2",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "node-cron": "^3.0.3",
    "p-limit": "^5.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "vite": "^5.4.0"
  }
}
